PORT=5050
NODE_ENV=development

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/sumat_eastvicians
PGSSL=false

# Generate a long random value, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# Comma-separated list of origins allowed to call this API (your deployed frontend URL(s))
FRONTEND_ORIGIN=http://localhost:8080,https://your-site.netlify.app

UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=25
